{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "KI-Guide",
  "version": "0.1.0",
  "identifier": "de.herknermedia.kiguide",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "KI-Guide mit Lara",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "publisher": "Herkner Media",
    "category": "Education",
    "shortDescription": "KI-Guide mit Lara – dein interaktiver KI-Kurs",
    "longDescription": "Lerne Künstliche Intelligenz mit Lara als persönliche KI-Begleiterin. 15 Video-Kapitel von den Grundlagen bis zu eigenen KI-Agenten.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": ["German", "English"]
      }
    }
  }
}
